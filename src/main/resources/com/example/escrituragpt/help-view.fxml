<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Text?>

<StackPane prefHeight="620" prefWidth="900"
           style="-fx-background-color: #1C1C24;"
           xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.escrituragpt.controller.HelpController">

    <!-- ═══ FONDO GEOMÉTRICO ═══ -->
    <Pane mouseTransparent="true">
        <Circle centerX="80"  centerY="80"  fill="#2E2A1A" opacity="0.70" radius="120" />
        <Circle centerX="820" centerY="60"  fill="#1E2430" opacity="0.65" radius="90"  />
        <Circle centerX="40"  centerY="560" fill="#28241A" opacity="0.70" radius="70"  />
        <Circle centerX="860" centerY="540" fill="#1E2228" opacity="0.60" radius="110" />
        <Circle centerX="450" centerY="310" fill="#242430" opacity="0.35" radius="200" />
        <Circle centerX="450" centerY="310" fill="#C9A84C" opacity="0.025" radius="300" />
        <Line startX="720" startY="0" endX="900" endY="180" stroke="#C9A84C" strokeWidth="0.8" opacity="0.12" />
        <Line startX="760" startY="0" endX="900" endY="140" stroke="#C9A84C" strokeWidth="0.8" opacity="0.09" />
        <Line startX="0" startY="380" endX="180" endY="620" stroke="#C9A84C" strokeWidth="0.8" opacity="0.10" />
        <Line startX="0" startY="420" endX="140" endY="620" stroke="#C9A84C" strokeWidth="0.8" opacity="0.08" />
        <Line startX="80" startY="200" endX="820" endY="200" stroke="#6A5828" strokeWidth="1" opacity="0.28" />
        <Line startX="80" startY="420" endX="820" endY="420" stroke="#6A5828" strokeWidth="1" opacity="0.28" />
        <Circle centerX="155" centerY="155" fill="#C9A84C" opacity="0.50" radius="2.0" />
        <Circle centerX="755" centerY="90"  fill="#C9A84C" opacity="0.48" radius="2.2" />
        <Circle centerX="820" centerY="470" fill="#C9A84C" opacity="0.42" radius="2.0" />
        <Text x="52"  y="82"  text="◆" opacity="0.35" style="-fx-font-size: 7px; -fx-fill: #C9A84C;" />
        <Text x="848" y="52"  text="◆" opacity="0.30" style="-fx-font-size: 8px; -fx-fill: #C9A84C;" />
        <Text x="55"  y="528" text="◆" opacity="0.28" style="-fx-font-size: 7px; -fx-fill: #C9A84C;" />
        <Text x="840" y="525" text="◆" opacity="0.30" style="-fx-font-size: 8px; -fx-fill: #C9A84C;" />
        <Text x="750" y="130" text="✏️" opacity="0.18" style="-fx-font-size: 28px;" />
        <Text x="100" y="510" text="📝" opacity="0.16" style="-fx-font-size: 26px;" />
        <Text x="108" y="295" text="✦"  opacity="0.16" style="-fx-font-size: 10px; -fx-fill: #C9A84C;" />
    </Pane>

    <!-- ═══ CONTENEDOR PRINCIPAL ═══ -->
    <VBox alignment="TOP_CENTER" spacing="0" style="-fx-background-color: transparent;">

        <!-- ── BARRA SUPERIOR ── -->
        <HBox alignment="CENTER_LEFT" prefHeight="64" prefWidth="900"
              style="-fx-background-color: #14141C; -fx-border-color: transparent transparent #C9A84C transparent; -fx-border-width: 0 0 1 0;">
            <effect><DropShadow color="#000000" offsetY="3" radius="10" spread="0.05" /></effect>
            <padding><Insets left="32" right="32" /></padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Text fill="#f8f7f7" style="-fx-font-size: 26px;" text="✏️" />
                <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 20px; -fx-font-weight: bold; -fx-fill: #C9A84C;" text="Escritura Rápida" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER" spacing="6"
                  style="-fx-background-color: #22201A; -fx-background-radius: 20; -fx-border-color: #C9A84C; -fx-border-radius: 20; -fx-border-width: 1; -fx-padding: 6 16 6 16;">
                <Text style="-fx-font-size: 14px;" text="❓" />
                <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 13px; -fx-fill: #C9A84C;" text="Ayuda" />
            </HBox>
        </HBox>

        <!-- Línea decorativa -->
        <Pane mouseTransparent="true" prefHeight="2" prefWidth="900" style="-fx-background-color: transparent;">
            <Line startX="0" startY="1" endX="900" endY="1" stroke="#C9A84C" strokeWidth="1" opacity="0.20" />
        </Pane>

        <!-- ── ZONA CENTRAL ── -->
        <StackPane VBox.vgrow="ALWAYS">
            <Circle centerX="450" centerY="250" fill="#C9A84C" mouseTransparent="true" opacity="0.04" radius="240" />

            <VBox alignment="CENTER" maxWidth="620" spacing="0"
                  style="-fx-background-color: #26262E; -fx-background-radius: 28; -fx-border-color: #C9A84C; -fx-border-radius: 28; -fx-border-width: 1; -fx-padding: 36 52 36 52;">
                <effect><DropShadow color="#C9A84C" offsetY="4" radius="32" spread="0.04" /></effect>

                <!-- Título -->
                <VBox alignment="CENTER" spacing="4" style="-fx-padding: 0 0 20 0;">
                    <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 28px; -fx-font-weight: bold; -fx-fill: #C9A84C;"
                          text="❓  ¿Cómo se juega?">
                        <effect><DropShadow color="#C9A84C" offsetY="2" radius="14" spread="0.04" /></effect>
                    </Text>
                </VBox>

                <!-- Separador -->
                <HBox alignment="CENTER" spacing="6" style="-fx-padding: 0 0 20 0;">
                    <Line startX="0" startY="0" endX="80" endY="0" stroke="#5A4A1A" strokeWidth="1" />
                    <Text style="-fx-font-size: 9px;  -fx-fill: #8A7030;" text="◇" />
                    <Line startX="0" startY="0" endX="20" endY="0" stroke="#7A6830" strokeWidth="1" />
                    <Text style="-fx-font-size: 13px; -fx-fill: #C9A84C;" text="✦" />
                    <Line startX="0" startY="0" endX="20" endY="0" stroke="#7A6830" strokeWidth="1" />
                    <Text style="-fx-font-size: 9px;  -fx-fill: #8A7030;" text="◇" />
                    <Line startX="0" startY="0" endX="80" endY="0" stroke="#5A4A1A" strokeWidth="1" />
                </HBox>

                <!-- Reglas -->
                <VBox alignment="CENTER_LEFT" spacing="12"
                      style="-fx-background-color: #1E1E28; -fx-background-radius: 14; -fx-border-color: #3A3828; -fx-border-radius: 14; -fx-border-width: 1; -fx-padding: 20 28 20 28;">

                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Text style="-fx-font-size: 18px;" text="🎯" />
                        <VBox spacing="2">
                            <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-fill: #C9A84C;" text="Objetivo" />
                            <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 12px; -fx-fill: #8890A0;" text="Escribe la palabra que aparece exactamente como se muestra." />
                        </VBox>
                    </HBox>

                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Text style="-fx-font-size: 18px;" text="⏱" />
                        <VBox spacing="2">
                            <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-fill: #C9A84C;" text="Tiempo" />
                            <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 12px; -fx-fill: #8890A0;" text="Empiezas con 20 segundos. Cada 5 niveles el tiempo baja 2 seg (mín. 2 seg)." />
                        </VBox>
                    </HBox>

                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Text style="-fx-font-size: 18px;" text="⌨️" />
                        <VBox spacing="2">
                            <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-fill: #C9A84C;" text="Controles" />
                            <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 12px; -fx-fill: #8890A0;" text="Presiona Enter o el botón Validar para enviar tu respuesta." />
                        </VBox>
                    </HBox>

                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Text style="-fx-font-size: 18px;" text="⚠️" />
                        <VBox spacing="2">
                            <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-fill: #C9784C;" text="Fin del juego" />
                            <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 12px; -fx-fill: #8890A0;" text="Un error ortográfico o agotar el tiempo reinicia el juego desde el nivel 1." />
                        </VBox>
                    </HBox>

                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Text style="-fx-font-size: 18px;" text="🏆" />
                        <VBox spacing="2">
                            <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-fill: #C9A84C;" text="Puntaje" />
                            <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 12px; -fx-fill: #8890A0;" text="Tu puntaje es el número de niveles consecutivos completados sin errores." />
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Botón Volver -->
                <VBox alignment="CENTER" style="-fx-padding: 24 0 0 0;">
                    <Button fx:id="backButton"
                            text="←   Volver al Menú"
                            onAction="#onBackButtonClicked"
                            prefHeight="46" prefWidth="220"
                            style="-fx-background-color: linear-gradient(to right, #8A6818, #C9A84C); -fx-background-radius: 23; -fx-text-fill: #1C1810; -fx-font-family: 'Georgia'; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: #E0C070; -fx-border-radius: 23; -fx-border-width: 0.8;">
                        <effect><DropShadow color="#8A6818" offsetY="4" radius="14" spread="0.10" /></effect>
                    </Button>
                </VBox>
            </VBox>
        </StackPane>

        <!-- Línea decorativa sobre footer -->
        <Pane mouseTransparent="true" prefHeight="2" prefWidth="900" style="-fx-background-color: transparent;">
            <Line startX="0" startY="1" endX="900" endY="1" stroke="#C9A84C" strokeWidth="1" opacity="0.20" />
        </Pane>

        <!-- ── BARRA INFERIOR ── -->
        <HBox alignment="CENTER" prefHeight="52" prefWidth="900"
              style="-fx-background-color: #14141C; -fx-border-color: #C9A84C transparent transparent transparent; -fx-border-width: 1 0 0 0;">
            <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 12px; -fx-fill: #5A4A2A;"
                  text="Mini Proyecto #1  ✦  Programación Orientada a Eventos" />
        </HBox>
    </VBox>
</StackPane>
