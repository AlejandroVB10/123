<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Text?>

<StackPane prefHeight="620" prefWidth="900"
           style="-fx-background-color: #1C1C24;"
           xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.escrituragpt.controller.MenuController">

    <!-- ═══ CAPA DE FONDO GEOMÉTRICO ═══ -->
    <Pane mouseTransparent="true">
        <!-- Manchas de luz -->
        <Circle centerX="80"  centerY="80"  fill="#2E2A1A" opacity="0.70" radius="120" />
        <Circle centerX="820" centerY="60"  fill="#1E2430" opacity="0.65" radius="90"  />
        <Circle centerX="40"  centerY="560" fill="#28241A" opacity="0.70" radius="70"  />
        <Circle centerX="860" centerY="540" fill="#1E2228" opacity="0.60" radius="110" />
        <Circle centerX="450" centerY="310" fill="#242430" opacity="0.35" radius="200" />
        <!-- Halos dorados -->
        <Circle centerX="450" centerY="310" fill="#C9A84C" opacity="0.025" radius="300" />
        <Circle centerX="450" centerY="310" fill="#C9A84C" opacity="0.018" radius="270" />
        <!-- Retícula diagonal esquina sup-derecha -->
        <Line startX="720" startY="0" endX="900" endY="180" stroke="#C9A84C" strokeWidth="0.8" opacity="0.12" />
        <Line startX="760" startY="0" endX="900" endY="140" stroke="#C9A84C" strokeWidth="0.8" opacity="0.09" />
        <Line startX="800" startY="0" endX="900" endY="100" stroke="#C9A84C" strokeWidth="0.8" opacity="0.07" />
        <Line startX="840" startY="0" endX="900" endY="60"  stroke="#C9A84C" strokeWidth="0.8" opacity="0.05" />
        <!-- Retícula diagonal esquina inf-izquierda -->
        <Line startX="0" startY="380" endX="180" endY="620" stroke="#C9A84C" strokeWidth="0.8" opacity="0.10" />
        <Line startX="0" startY="420" endX="140" endY="620" stroke="#C9A84C" strokeWidth="0.8" opacity="0.08" />
        <Line startX="0" startY="460" endX="100" endY="620" stroke="#C9A84C" strokeWidth="0.8" opacity="0.06" />
        <!-- Líneas horizontales tipo cuaderno -->
        <Line startX="80" startY="200" endX="820" endY="200" stroke="#6A5828" strokeWidth="1"   opacity="0.30" />
        <Line startX="80" startY="420" endX="820" endY="420" stroke="#6A5828" strokeWidth="1"   opacity="0.30" />
        <!-- Constelación de puntos dorados -->
        <Circle centerX="155" centerY="155" fill="#C9A84C" opacity="0.55" radius="2.0" />
        <Circle centerX="172" centerY="142" fill="#C9A84C" opacity="0.40" radius="1.4" />
        <Circle centerX="168" centerY="170" fill="#C9A84C" opacity="0.45" radius="1.8" />
        <Circle centerX="755" centerY="90"  fill="#C9A84C" opacity="0.50" radius="2.2" />
        <Circle centerX="772" centerY="75"  fill="#C9A84C" opacity="0.38" radius="1.5" />
        <Circle centerX="820" centerY="470" fill="#C9A84C" opacity="0.45" radius="2.0" />
        <Circle centerX="840" centerY="488" fill="#C9A84C" opacity="0.35" radius="1.5" />
        <Circle centerX="60"  centerY="310" fill="#C9A84C" opacity="0.30" radius="1.5" />
        <Circle centerX="878" centerY="200" fill="#C9A84C" opacity="0.28" radius="1.5" />
        <Circle centerX="300" centerY="60"  fill="#C9A84C" opacity="0.25" radius="1.2" />
        <Circle centerX="600" centerY="570" fill="#C9A84C" opacity="0.28" radius="1.5" />
        <!-- Diamantes ornamentales -->
        <Text x="52"  y="82"  text="◆" opacity="0.38" style="-fx-font-size: 7px; -fx-fill: #C9A84C;" />
        <Text x="848" y="52"  text="◆" opacity="0.32" style="-fx-font-size: 8px; -fx-fill: #C9A84C;" />
        <Text x="55"  y="528" text="◆" opacity="0.30" style="-fx-font-size: 7px; -fx-fill: #C9A84C;" />
        <Text x="840" y="525" text="◆" opacity="0.32" style="-fx-font-size: 8px; -fx-fill: #C9A84C;" />
        <!-- Íconos decorativos flotantes -->
        <Text x="750" y="130" text="✏️" opacity="0.20" style="-fx-font-size: 28px;" />
        <Text x="100" y="510" text="📝" opacity="0.18" style="-fx-font-size: 26px;" />
        <Text x="800" y="490" text="⌨️" opacity="0.16" style="-fx-font-size: 24px;" />
        <Text x="50"  y="160" text="✨" opacity="0.22" style="-fx-font-size: 20px;" />
        <Text x="108" y="295" text="✦"  opacity="0.18" style="-fx-font-size: 10px; -fx-fill: #C9A84C;" />
        <Text x="792" y="385" text="✦"  opacity="0.16" style="-fx-font-size: 8px;  -fx-fill: #C9A84C;" />
    </Pane>

    <!-- ═══ CONTENEDOR PRINCIPAL ═══ -->
    <VBox alignment="TOP_CENTER" spacing="0" style="-fx-background-color: transparent;">

        <!-- ── BARRA SUPERIOR ── -->
        <HBox alignment="CENTER_LEFT" prefHeight="64" prefWidth="900"
              style="-fx-background-color: #14141C; -fx-border-color: transparent transparent #C9A84C transparent; -fx-border-width: 0 0 1 0;">
            <effect><DropShadow color="#000000" offsetY="3" radius="10" spread="0.05" /></effect>
            <padding><Insets left="32" right="32" /></padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Text fill="#f8f7f7" style="-fx-font-size: 26px;" text="✏️" />
                <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 20px; -fx-font-weight: bold; -fx-fill: #C9A84C;" text="Escritura Rápida" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <!-- Badge "Menú Principal" -->
            <HBox alignment="CENTER" spacing="6"
                  style="-fx-background-color: #22201A; -fx-background-radius: 20; -fx-border-color: #C9A84C; -fx-border-radius: 20; -fx-border-width: 1; -fx-padding: 6 16 6 16;">
                <Text style="-fx-font-size: 13px;" text="🏠" />
                <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 13px; -fx-fill: #C9A84C;" text="Menú Principal" />
            </HBox>
        </HBox>

        <!-- Línea decorativa -->
        <Pane mouseTransparent="true" prefHeight="2" prefWidth="900" style="-fx-background-color: transparent;">
            <Line startX="0" startY="1" endX="900" endY="1" stroke="#C9A84C" strokeWidth="1" opacity="0.20" />
        </Pane>

        <!-- ── ZONA CENTRAL ── -->
        <StackPane VBox.vgrow="ALWAYS">
            <Circle centerX="450" centerY="250" fill="#C9A84C" mouseTransparent="true" opacity="0.04" radius="240" />

            <!-- Tarjeta central -->
            <VBox alignment="CENTER" maxWidth="580" spacing="0"
                  style="-fx-background-color: #26262E; -fx-background-radius: 28; -fx-border-color: #C9A84C; -fx-border-radius: 28; -fx-border-width: 1; -fx-padding: 40 52 40 52;">
                <effect><DropShadow color="#C9A84C" offsetY="4" radius="32" spread="0.04" /></effect>

                <!-- Título -->
                <VBox alignment="CENTER" spacing="6" style="-fx-padding: 0 0 28 0;">
                    <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 38px; -fx-font-weight: bold; -fx-fill: #C9A84C;"
                          text="✏  Escritura Rápida">
                        <effect><DropShadow color="#C9A84C" offsetY="2" radius="18" spread="0.05" /></effect>
                    </Text>
                    <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 14px; -fx-fill: #606878;"
                          text="¿Puedes escribir más rápido que el reloj?" />
                </VBox>

                <!-- Separador -->
                <HBox alignment="CENTER" spacing="6" style="-fx-padding: 0 0 24 0;">
                    <Line startX="0" startY="0" endX="80" endY="0" stroke="#5A4A1A" strokeWidth="1" />
                    <Text style="-fx-font-size: 9px;  -fx-fill: #8A7030;" text="◇" />
                    <Line startX="0" startY="0" endX="20" endY="0" stroke="#7A6830" strokeWidth="1" />
                    <Text style="-fx-font-size: 13px; -fx-fill: #C9A84C;" text="✦" />
                    <Line startX="0" startY="0" endX="20" endY="0" stroke="#7A6830" strokeWidth="1" />
                    <Text style="-fx-font-size: 9px;  -fx-fill: #8A7030;" text="◇" />
                    <Line startX="0" startY="0" endX="80" endY="0" stroke="#5A4A1A" strokeWidth="1" />
                </HBox>

                <!-- Instrucciones -->
                <VBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-background-color: #1E1E28; -fx-background-radius: 14; -fx-border-color: #3A3828; -fx-border-radius: 14; -fx-border-width: 1; -fx-padding: 18 24 18 24;">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Text style="-fx-font-size: 14px;" text="📋" />
                        <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-fill: #C9A84C;" text="Cómo jugar" />
                    </HBox>
                    <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 13px; -fx-fill: #8890A0;" text="◆  Aparece una palabra o frase en pantalla" />
                    <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 13px; -fx-fill: #8890A0;" text="◆  Escríbela exactamente como aparece" />
                    <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 13px; -fx-fill: #8890A0;" text="◆  Tienes 20 segundos por nivel" />
                    <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 13px; -fx-fill: #8890A0;" text="◆  Cada 5 niveles el tiempo disminuye 2 seg" />
                    <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 13px; -fx-fill: #C9784C;" text="◆  ¡Un error y el juego termina!" />
                </VBox>

                <!-- Botones JUGAR y AYUDA -->
                <VBox alignment="CENTER" spacing="12" style="-fx-padding: 28 0 0 0;">
                    <Button fx:id="playButton"
                            text="▶   JUGAR"
                            onAction="#onPlayButtonClicked"
                            prefHeight="50" prefWidth="220"
                            style="-fx-background-color: linear-gradient(to right, #8A6818, #C9A84C); -fx-background-radius: 25; -fx-text-fill: #1C1810; -fx-font-family: 'Georgia'; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: #E0C070; -fx-border-radius: 25; -fx-border-width: 0.8;">
                        <effect><DropShadow color="#8A6818" offsetY="4" radius="14" spread="0.10" /></effect>
                    </Button>
                    <Button fx:id="helpButton"
                            text="❓   Ayuda"
                            onAction="#onHelpButtonClicked"
                            prefHeight="40" prefWidth="220"
                            style="-fx-background-color: #2A2418; -fx-background-radius: 20; -fx-text-fill: #C9A84C; -fx-font-family: 'Georgia'; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: #C9A84C; -fx-border-radius: 20; -fx-border-width: 1; -fx-padding: 7 18 7 18;" />
                </VBox>

            </VBox>
        </StackPane>

        <!-- Línea decorativa sobre footer -->
        <Pane mouseTransparent="true" prefHeight="2" prefWidth="900" style="-fx-background-color: transparent;">
            <Line startX="0" startY="1" endX="900" endY="1" stroke="#C9A84C" strokeWidth="1" opacity="0.20" />
        </Pane>

        <!-- ── BARRA INFERIOR ── -->
        <HBox alignment="CENTER" prefHeight="52" prefWidth="900"
              style="-fx-background-color: #14141C; -fx-border-color: #C9A84C transparent transparent transparent; -fx-border-width: 1 0 0 0;">
            <Text style="-fx-font-family: 'Georgia'; -fx-font-size: 12px; -fx-fill: #5A4A2A;"
                  text="Mini Proyecto #1  ✦  Programación Orientada a Eventos" />
        </HBox>

    </VBox>
</StackPane>
